---
import { Image } from "astro:assets";

interface Props {
  src: string | ImageMetadata;
  alt?: string;
  caption?: string;
  class?: string;
}

const { src, alt = "", caption, class: className } = Astro.props;
---

<figure class={className}>
  {
    typeof src === "string" ? (
      <img src={src} alt={alt} />
    ) : (
      <Image src={src} alt={alt} />
    )
  }
  {caption && <figcaption>{caption}</figcaption>}
</figure>
