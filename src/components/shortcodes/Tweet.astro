---
interface Props {
  id: string;
  user?: string;
}

const { id, user = "twitter" } = Astro.props;
const url = `https://twitter.com/${user}/status/${id}`;
---

<blockquote class="twitter-tweet">
  <a href={url}></a>
</blockquote>
<script
  async
  src="https://platform.twitter.com/widgets.js"
  charset="utf-8"
  is:inline></script>
