---
import CategoryIcon from "./CategoryIcon.astro";
import BackgroundDevice from "./BackgroundDevice.astro";
import Container from "./grid/Container.astro";
import Row from "./grid/Row.astro";
import Col from "./grid/Col.astro";

interface Props {
  title: string;
  superTitle?: string;
  subTitle?: string;
  darkBg?: boolean;
  categoryIcon?: string;
  extraClass?: string;
}

const {
  title,
  superTitle,
  subTitle,
  darkBg = false,
  categoryIcon,
  extraClass,
} = Astro.props;

const sectionClasses = [
  "section",
  "section__page-header",
  darkBg && "-has-dark-bg",
  "-has-background-device",
  extraClass,
]
  .filter(Boolean)
  .join(" ");
---

<section class={sectionClasses}>
  <Container classNameSuffix="page-header">
    {categoryIcon && <CategoryIcon category={categoryIcon} />}

    <Row classNameSuffix="page-header">
      <Col
        xs={8}
        offsetXs={3}
        sm={6}
        offsetSm={3}
        md={8}
        offsetMd={2}
        lg={8}
        offsetLg={2}
      >
        <div class="page-header__hgroup">
          {superTitle && <h6 class="page-header__super-title">{superTitle}</h6>}
          <h1 class="page-header__title">{title}</h1>
          {subTitle && <p class="page-header__sub-title">{subTitle}</p>}
        </div>
      </Col>
    </Row>
    <BackgroundDevice />
  </Container>
</section>
