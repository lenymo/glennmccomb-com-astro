---
import { Image } from "astro:assets";
import BackgroundDevice from "./BackgroundDevice.astro";
import Container from "./grid/Container.astro";
import Row from "./grid/Row.astro";
import Col from "./grid/Col.astro";

interface Props {
  title: string;
  date: Date;
  categories: string[];
  featured?: ImageMetadata;
  darkBg?: boolean;
  superTitle?: string;
  subTitle?: string;
}

const {
  title,
  date,
  categories,
  featured,
  darkBg = false,
  superTitle,
  subTitle,
} = Astro.props;

const day = date.getUTCDate();
const daySuffix = [1, 21, 31].includes(day)
  ? "st"
  : [2, 22].includes(day)
    ? "nd"
    : [3, 23].includes(day)
      ? "rd"
      : "th";
const monthShort = date.toLocaleString("en-US", {
  month: "short",
  timeZone: "UTC",
});
const yearShort = date.toLocaleString("en-US", {
  year: "numeric",
  timeZone: "UTC",
});

const sectionClasses = [
  "section",
  "section__page-header",
  featured && "-has-featured",
  darkBg && "-has-dark-bg",
  "-has-background-device",
  "section__article-header",
]
  .filter(Boolean)
  .join(" ");

const slugify = (s: string) => s.toLowerCase().replace(/\s+/g, "-");
---

<section class={sectionClasses}>
  <Container classNameSuffix="page-header">
    <date class="article-date article-header__date">
      <span class="article-date__month article-header__date-month"
        >{monthShort}</span
      >
      <span class="article-date__day article-header__date-day">{day}</span>
      <span class="article-date__year article-header__date-year"
        >{yearShort}</span
      >
    </date>

    <Row classNameSuffix="page-header">
      <Col
        xs={8}
        offsetXs={3}
        sm={6}
        offsetSm={3}
        md={8}
        offsetMd={2}
        lg={8}
        offsetLg={2}
      >
        <div class="page-header__hgroup article-header__hgroup">
          {superTitle && <h6 class="page-header__super-title">{superTitle}</h6>}
          <h1 class="page-header__title article-header__title">{title}</h1>
          {subTitle && <p class="page-header__sub-title">{subTitle}</p>}
          {
            categories.length > 0 && (
              <ul class="article-header__categories">
                {categories.map((category) => (
                  <li
                    class={`article-header__category article-header__category-${slugify(category)}`}
                  >
                    <a
                      class="article-header__category-link"
                      href={`/categories/${slugify(category)}`}
                    >
                      {category}
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </Col>
    </Row>
    <BackgroundDevice />
  </Container>

  {
    featured && (
      <div class="page-header__featured-image -is-object-fit-parent">
        <Image
          class="page-header__featured-image-picture-img -uses-object-fit"
          src={featured}
          alt=""
          widths={[640, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    )
  }
</section>
