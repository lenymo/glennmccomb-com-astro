---
interface Props {
  category: string;
}

const { category } = Astro.props;
const normalized = category.toLowerCase();
---

<div class="page-header__icon">
  <div class="page-header__icon-wrapper">
    {normalized === "development" && <>{`</>`}</>}

    {
      normalized === "design" && (
        <div class="page-header__icon-bezier-curve">
          <div class="page-header__icon-bezier-curve__curve" />
          <div class="page-header__icon-bezier-curve__handle" />
          <div class="page-header__icon-bezier-curve__point" />
          <div class="page-header__icon-bezier-curve__control top" />
          <div class="page-header__icon-bezier-curve__control bottom" />
        </div>
      )
    }

    {
      normalized === "gaming" && (
        <div class="page-header__icon-gaming-keys">
          <div class="page-header__icon-gaming-key w">W</div>
          <div class="page-header__icon-gaming-key a">A</div>
          <div class="page-header__icon-gaming-key s">S</div>
          <div class="page-header__icon-gaming-key d">D</div>
        </div>
      )
    }

    {
      normalized === "nba" && (
        <svg
          class="basketball"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 98 98"
        >
          <g class="outlines">
            <path
              d="M13.81,83A48.86,48.86,0,0,0,46,98.82V54H30.55A40.79,40.79,0,0,1,13.81,83Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M91.08,76.7A48.64,48.64,0,0,0,98.82,54H77.5A32.79,32.79,0,0,0,91.08,76.7Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M13.81,17A40.79,40.79,0,0,1,30.55,46H46V1.18A48.86,48.86,0,0,0,13.81,17Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M98.82,46a48.64,48.64,0,0,0-7.74-22.7A32.79,32.79,0,0,0,77.5,46Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M86.19,17A48.86,48.86,0,0,0,54,1.18V46H69.45A40.79,40.79,0,0,1,86.19,17Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M69.45,54H54V98.82A48.86,48.86,0,0,0,86.19,83,40.79,40.79,0,0,1,69.45,54Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M8.92,23.3A48.64,48.64,0,0,0,1.18,46H22.5A32.79,32.79,0,0,0,8.92,23.3Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
            <path
              d="M1.18,54A48.64,48.64,0,0,0,8.92,76.7,32.79,32.79,0,0,0,22.5,54Z"
              transform="translate(-1 -1)"
              fill="#812e1a"
            />
          </g>
          <path
            class="lines"
            d="M99,50c0-1.35-.07-2.68-.18-4H77.5A32.79,32.79,0,0,1,91.08,23.3,50.43,50.43,0,0,0,86.19,17,40.79,40.79,0,0,0,69.45,46H54V1.18C52.68,1.07,51.35,1,50,1s-2.68.07-4,.18V46H30.55A40.79,40.79,0,0,0,13.81,17,50.43,50.43,0,0,0,8.92,23.3,32.79,32.79,0,0,1,22.5,46H1.18C1.07,47.32,1,48.65,1,50s.07,2.68.18,4H22.5A32.79,32.79,0,0,1,8.92,76.7,50.43,50.43,0,0,0,13.81,83,40.79,40.79,0,0,0,30.55,54H46V98.82c1.32.11,2.65.18,4,.18s2.68-.07,4-.18V54H69.45A40.79,40.79,0,0,0,86.19,83a50.43,50.43,0,0,0,4.89-6.34A32.79,32.79,0,0,1,77.5,54H98.82C98.93,52.68,99,51.35,99,50Z"
            transform="translate(-1 -1)"
            fill="#983826"
          />
        </svg>
      )
    }
  </div>
</div>
