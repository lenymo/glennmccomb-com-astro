---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/PageHeader.astro";
import SectionArticlesSummary from "../../components/SectionArticlesSummary.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Articles" bodyClass="articles articles-articles">
  <PageHeader title="Articles" darkBg />
  <SectionArticlesSummary articles={sorted} />
</Layout>
